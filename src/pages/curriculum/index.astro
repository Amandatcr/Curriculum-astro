---
import Layout from "../../layouts/Layout.astro";
import HeaderResumen from "../../components/HeaderResumen.astro";
import Estudios from "../../components/Estudios.astro";
import ExperienciasLaborales from "../../components/ExperienciasLaborales.astro";
import Contactos from "../../components/Contactos.astro";
import CVSection from "../../components/CVSection.astro";
import {
    conocimientosTecnicos,
    actitudes,
    masInformacion,
} from "../../data/CVData";
---

<Layout title="Curriculum Amanda Cruz">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8 mt-10 mb-10 p-6">
        <main class="">
            <HeaderResumen />
            <Estudios />
            <ExperienciasLaborales />
        </main>

        <aside class="bg-rose-50 p-6 rounded-xl space-y-6">
            <section class="mb-5 mt-5 ml-33">
                <img
                    src="/img/imgCV.jpeg"
                    alt="Foto Amanda"
                    class="w-36 h-36 rounded-full object-cover shadow"
                />
            </section>
            <Contactos />
            <CVSection
                titulo="Conocimientos técnicos"
                items={conocimientosTecnicos}
            />
            <CVSection titulo="Actitudes" items={actitudes} />
            <CVSection titulo="Más información" items={masInformacion} />
        </aside>
    </div>
</Layout>
