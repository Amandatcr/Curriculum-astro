---
import Estudio from "./Estudio.astro";
import TitleSection from "./TitleSection.astro";


const estudios =[
    {
        titulo: "TÉCNICO EN DESARROLLO APLICACIONES WEB",
        centro: "IES Vista Alegre - Madrid",
        fecha:"(2024-2026)"
    },
    {
        titulo: "CONSULTOR FUNCIONAL SAP-CO",
        centro: "ALTIM Formación – Getafe",
        fecha:"(01/2024-04/2024)"
    },
    {
        titulo: "CONSULTOR FUNCIONAL SAP-FI",
        centro: "Escuela de Negocios La Salle – Madrid",
        fecha:"(03/2015-12/2015)"
    },
    {
        titulo: "TECNICO SUPERIOR, ADMINISTRACION Y FINANZAS",
        centro: "IES El Lago – Madrid",
        fecha:"(2007-2009)" 
    }




];
---
<section>
    <TitleSection titulo = "Formación"/>
    {estudios.map(estudio=>(
        <Estudio
            titulo={estudio.titulo}
            centro={estudio.centro}
            fecha={estudio.fecha}
        />
    ))}

</section>


